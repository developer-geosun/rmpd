# Змінні середовища для docker compose (скопіюйте в .env)

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=rmpd
MYSQL_USER=rmpd
MYSQL_PASSWORD=rmpd

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/rmpd?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=rmpd
SPRING_DATASOURCE_PASSWORD=rmpd

RMPD_XSD_PATH=/app/specs/rmpd/RMPD_v20.11.2024

RMPD_JWT_SECRET=change-me-in-production-use-256-bit-secret-key!!

PUESC_ENV=test
PUESC_CLIENT=mock
PUESC_WSDL_URL=https://te-ws.puesc.gov.pl/seap_wsChannel/DocumentHandlingPort?wsdl
PUESC_TARGET_SYSTEM=SENT
STORAGE_CMR_PATH=/data/cmr
RMPD_MAIL_ENABLED=false
